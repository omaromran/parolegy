# Database (required) — Prisma reads DATABASE_URL at build and runtime
#
# Local (PostgreSQL): e.g. Docker
#   docker run --name parolegy-pg -e POSTGRES_PASSWORD=postgres -e POSTGRES_DB=parolegy -p 5432:5432 -d postgres:16
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/parolegy"
#
# Production (Vercel / Netlify / Railway): create a Postgres database (Neon, Supabase, Vercel Postgres, etc.),
# then add DATABASE_URL in the host’s Environment Variables — it is NOT read from .env files in the repo.
# Example:
#   DATABASE_URL="postgresql://USER:PASSWORD@HOST.aws.neon.tech/neondb?sslmode=require"
#
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/parolegy"

# Auth (required for signup/login)
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# Optional: site password protection (omit or set to empty string to disable the gate)
# SITE_PASSWORD="your-password"

# Public URL for emails, Stripe redirects, and password-reset links (production: your domain)
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
# NEXTAUTH_URL="https://your-domain.com"

# Resend (transactional email). Without RESEND_API_KEY, emails log to the console only.
# RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="Parolegy <notifications@your-domain.com>"
# STAFF_NOTIFY_EMAIL="team@your-domain.com"

# Stripe (single product / price). When both STRIPE_SECRET_KEY and STRIPE_PRICE_ID are set,
# client/family accounts must pay before dashboard and most APIs.
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PRICE_ID="price_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."  # for POST /api/stripe/webhook
# Optional label shown on the marketing pricing page:
# NEXT_PUBLIC_PRODUCT_PRICE_LABEL="$499 one-time"

# Optional: embed Calendly on /onboarding
# NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/your-org/consult"

# Document uploads — local disk (no AWS)
# Default: ./uploads under the app working directory.
# On Railway: add a Volume mounted at /app/uploads and set:
#   UPLOADS_DIR=/app/uploads
# (See railway.toml in the repo for the same steps.)
# UPLOADS_DIR="/app/uploads"

# Optional: S3-compatible storage instead of local disk
# Without S3, files are stored under UPLOADS_DIR or ./uploads — ephemeral on hosts without a volume.
# Set all of the following to use S3-compatible storage
# (AWS S3, Cloudflare R2, MinIO, etc.). Keys in the bucket match DB storageKey: uploads/{caseId}/{file}
# S3_BUCKET="your-bucket"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."
# AWS_REGION="us-east-1"
# Optional (R2 / MinIO / custom endpoint):
# S3_ENDPOINT="https://....r2.cloudflarestorage.com"
# S3_FORCE_PATH_STYLE="true"

# OpenAI (required for campaign generation - self-serve)
OPENAI_API_KEY="sk-your-openai-api-key-here"
# Optional: overrides default gpt-4o. Do not use retired names like gpt-4-turbo-preview.
# OPENAI_MODEL="gpt-4o"
